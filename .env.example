# ── Anthropic LLM ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model used for fast tasks (classification, hallucination check)
LLM_MODEL=claude-haiku-4-5-20251001

# Model used for final answer generation
RESPONSE_LLM_MODEL=claude-sonnet-4-6

# ── Database (SQLite) ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data_store/campus_help.db
CHECKPOINT_DB_PATH=./data_store/checkpoints.db

# ── ChromaDB (embedded) ───────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data_store/chroma_db
CHROMA_COLLECTION_NAME=campus_docs

# ── RAG Settings ──────────────────────────────────────────────────────────────
DATA_DIR=./data
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3
CONFIDENCE_THRESHOLD=0.7

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
EMBEDDING_DEVICE=cpu

# ── LangSmith Monitoring (optional) ──────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=campus-help-agent

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT=20/minute
MAX_QUERY_LENGTH=1000
