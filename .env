# ── Groq LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# Model used for fast tasks (classification, hallucination check)
LLM_MODEL=llama-3.1-8b-instant

# Model used for final answer generation
RESPONSE_LLM_MODEL=llama-3.3-70b-versatile

# ── Firebase ──────────────────────────────────────────────────────────────────
# Paste your service account JSON as a minified single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# Firebase Web API Key (Project Settings → General → Web API Key)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# ── LangGraph Checkpointer (SQLite — internal only) ───────────────────────────
CHECKPOINT_DB_PATH=./data_store/checkpoints.db

# ── ChromaDB (embedded) ───────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data_store/chroma_db
CHROMA_COLLECTION_NAME=campus_docs

# ── RAG Settings ──────────────────────────────────────────────────────────────
DATA_DIR=./data
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3
CONFIDENCE_THRESHOLD=0.7

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
EMBEDDING_DEVICE=cpu

# ── LangSmith Monitoring (optional) ──────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=campus-help-agent

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT=20/minute
MAX_QUERY_LENGTH=1000
